# ═══════════════════════════════════════════════════════════════════════════════
#  ValidatorsGesi – Git Ignore (Optimizado para Auto-Update)
# ═══════════════════════════════════════════════════════════════════════════════

# --- Archivos de Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.env
venv/
env/
ENV/

# --- Archivos del Sistema ---
.DS_Store
Thumbs.db
desktop.ini

# --- PyInstaller (Compilación) ---
# Ignoramos la carpeta build porque solo tiene archivos temporales
build/
# Ignoramos los archivos de especificación (opcional, si quieres guardarlos quita la línea)
*.spec

# --- EXCEPCIÓN CRÍTICA PARA EL AUTO-UPDATE ---
# Ignoramos la carpeta dist por defecto...
dist/
# ...PERO obligamos a Git a incluir los ejecutables finales
!dist/Odin.exe
!dist/Updater.exe

# --- Otros ejecutables e instaladores ---
# Ignoramos instaladores pesados generados por Inno Setup
output_installer/
# Ignoramos cualquier otro .exe que no sea el de dist (para evitar basura)
*.exe
!dist/*.exe

# --- Archivos de Logs y Datos Temporales ---
*.log
update_log.txt
error_log.txt
gesi_update_*/
extracted/

# --- Archivos de base de datos y diseño ---
*.sqlite3
# Si usas algún editor como VS Code o PyCharm
.vscode/
.idea/